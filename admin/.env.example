# Copy to .env.local for local development, or set these as real env vars
# in your deployment platform.

# backend-core's URL (see ../backend-core/).
NEXT_PUBLIC_CORE_API_URL=http://localhost:8090

# Firebase Web app config — register a new Web app in the Firebase console
# for project "aplikasi-raya" (Project Settings > Add app > Web) to get
# these; see README.md's "Firebase Web app setup" section.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=aplikasi-raya
NEXT_PUBLIC_FIREBASE_APP_ID=
