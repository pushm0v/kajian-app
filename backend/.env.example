# Copy this file to .env and adjust for your homelab setup.

# Hugging Face model id. Change to Qwen3-ASR-0.6B for lower VRAM use.
ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B

# Fraction of GPU memory vLLM is allowed to reserve. Both official Qwen3-ASR
# vLLM examples use 0.8; lower this on a GPU shared with other workloads.
ASR_GPU_MEMORY_UTILIZATION=0.8

# Chunk size used both to stay under the model's ~20min/call limit and to
# produce approximate segment timestamps (Qwen3-ASR has no built-in
# timestamps — see backend/README.md for why).
ASR_CHUNK_SECONDS=30
ASR_CHUNK_OVERLAP_SECONDS=1

# Reject uploads larger than this (bytes). Default: 300MB.
ASR_MAX_UPLOAD_BYTES=314572800

# Bearer token required on both the /transcribe endpoint (Authorization
# header) and the /transcribe/stream WebSocket (?token=... query param,
# since bearer headers don't apply cleanly to WS handshakes). Leave empty
# for LAN-only / trusted-network use; set this before exposing the server
# past your homelab network (e.g. via a reverse proxy / tunnel).
ASR_API_TOKEN=

# Scratch directory for uploaded audio before/while decoding.
ASR_WORK_DIR=/tmp/kajian-asr

# --- Live streaming (/transcribe/stream) -----------------------------------
# These map to qwen_asr's init_streaming_state(...) kwargs. Defaults match
# the official Qwen3-ASR streaming example. See backend/README.md for what
# each one controls before changing them.
ASR_STREAM_CHUNK_SIZE_SEC=2.0
ASR_STREAM_UNFIXED_CHUNK_NUM=2
ASR_STREAM_UNFIXED_TOKEN_NUM=5
