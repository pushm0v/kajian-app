# Copy this file to .env and adjust for your homelab setup.

# Hugging Face model id. Change to Qwen3-ASR-0.6B for lower VRAM use.
ASR_MODEL_ID=Qwen/Qwen3-ASR-1.7B

# "cuda", "cpu", or "auto" to detect at startup.
ASR_DEVICE=auto

# "bfloat16", "float16", or "float32". Ignored on CPU (always float32).
ASR_TORCH_DTYPE=bfloat16

# Chunk size used both to stay under the model's ~20min/call limit and to
# produce approximate segment timestamps (Qwen3-ASR has no built-in
# timestamps — see backend/README.md for why).
ASR_CHUNK_SECONDS=30
ASR_CHUNK_OVERLAP_SECONDS=1

# Reject uploads larger than this (bytes). Default: 300MB.
ASR_MAX_UPLOAD_BYTES=314572800

# Bearer token the app must send as `Authorization: Bearer <token>`. Leave
# empty for LAN-only / trusted-network use; set this before exposing the
# server past your homelab network (e.g. via a reverse proxy / tunnel).
ASR_API_TOKEN=

# Scratch directory for uploaded audio before/while decoding.
ASR_WORK_DIR=/tmp/kajian-asr
