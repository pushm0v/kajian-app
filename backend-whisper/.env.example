# Copy this file to .env and adjust for your homelab setup.

# faster-whisper model size, or a Hugging Face/CTranslate2 model id/path.
WHISPER_MODEL_SIZE=large-v3

# "cuda" or "cpu".
WHISPER_DEVICE=cuda

# "float16" (~6GB VRAM, highest accuracy) or "int8_float16" (~3GB VRAM,
# small accuracy tradeoff — a good choice if sharing a GPU with another
# model, e.g. running alongside ../backend/'s Qwen3-ASR container).
WHISPER_COMPUTE_TYPE=float16

# Reject uploads larger than this (bytes). Default: 300MB.
WHISPER_MAX_UPLOAD_BYTES=314572800

# Bearer token the app must send as `Authorization: Bearer <token>`. Leave
# empty for LAN-only / trusted-network use; set this before exposing the
# server past your homelab network (e.g. via a reverse proxy / tunnel).
WHISPER_API_TOKEN=

# Scratch directory for uploaded audio before transcription.
WHISPER_WORK_DIR=/tmp/kajian-whisper
