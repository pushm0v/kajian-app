# Copy this file to .env and fill in real values before deploying.
# When using docker-compose.yml, DATABASE_URL and S3_ENDPOINT_URL are
# overridden to the container-network hostnames automatically — you don't
# need to set those two here for a docker-compose deploy.

# --- Database ---
DATABASE_URL=postgresql+asyncpg://kajian:kajian@localhost:5432/kajian

# --- Firebase Auth ---
# Path to a service account JSON key. Get one from the Firebase console:
# Project Settings > Service Accounts > Generate new private key.
# Mount this file into the container (see docker-compose.yml) rather than
# baking it into the image.
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-service-account.json
# DEV ONLY — never set this in production. Skips real Firebase token
# verification and trusts the raw bearer token value as a UID stand-in.
CORE_DEV_AUTH_BYPASS=false

# --- Object storage (MinIO / S3) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=kajian-audio
S3_REGION=us-east-1
S3_USE_SSL=false
PRESIGNED_URL_TTL_SECONDS=3600

# --- ASR worker proxy ---
# Point these at your already-deployed ../backend/ and ../backend-whisper/
# instances. Leave either empty to disable that model entirely.
QWEN_BACKEND_URL=http://localhost:8081
WHISPER_BACKEND_URL=http://localhost:8082
QWEN_BACKEND_TOKEN=
WHISPER_BACKEND_TOKEN=

# --- AI notes (Anthropic) ---
ANTHROPIC_API_KEY=
DEFAULT_NOTES_MODEL=claude-sonnet-5

# --- Misc ---
CORE_MAX_UPLOAD_BYTES=314572800
CORE_WORK_DIR=/tmp/kajian-core
# Comma-separated list of allowed origins for the admin app (../admin/).
# "*" is fine for local development only.
CORE_CORS_ORIGINS=*
